# ============================================================
# Agent Contest Demo - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# cp .env.example .env

# --- Model Gateway (required) ---
# OpenAI-compatible chat completions endpoint.
# Examples:
#   https://api.openai.com/v1
#   https://your-proxy.example.com/v1
MODEL_BASE_URL=
MODEL_API_KEY=
MODEL_NAME=

# Or specify the full chat completions URL directly:
# MODEL_CHAT_COMPLETIONS_URL=https://api.openai.com/v1/chat/completions

# --- Model Parameters (optional) ---
AGENT_DEMO_TEMPERATURE=0.2
AGENT_DEMO_MAX_TOKENS=0
AGENT_DEMO_STREAM=true
AGENT_DEMO_TIMEOUT_SECONDS=600
AGENT_DEMO_TOOL_OUTPUT_MAX_CHARS=65536

# --- Agent Behavior ---
# Set to false to disable LLM and force custom ContestantAgent.solve()
AGENT_DEMO_USE_LLM=true

# Max tool-calling iterations per question
AGENT_DEMO_MAX_ITER=100

# Maximum answer-checker correction rounds
AGENT_DEMO_MAX_FIX_ROUNDS=2

# Use native OpenAI-style tools (true) or JSON prompt-based tools (false)
AGENT_DEMO_NATIVE_TOOLS=true

# Fallback to JSON tool loop if native tools fail
AGENT_DEMO_JSON_TOOL_FALLBACK=true

# --- Contest Metadata ---
# Package ID for contest submission (if required by the platform)
PACKAGE_ID=
